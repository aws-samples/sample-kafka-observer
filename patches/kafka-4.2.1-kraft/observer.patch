+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+package org.apache.kafka.controller;
+
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+
+import java.nio.file.Files;
+import java.nio.file.Path;
+import java.nio.file.Paths;
+import java.util.ArrayList;
+import java.util.Collections;
+import java.util.HashSet;
+import java.util.List;
+import java.util.Set;
+
+/**
+ * === OBSERVER PATCH (KRaft controller side) ===
+ * Controller-side source of observer broker ids. Same file format and semantics as
+ * kafka.observer.ObserverIds (core, ZK/broker side), but pure Java because the
+ * metadata module must not depend on core.
+ *
+ * Semantics:
+ *   - File (default /opt/kafka/observer.ids, override via KAFKA_OBSERVER_IDS_FILE):
+ *     one id per line or comma/whitespace separated; '#' full-line comments; empty file = no observers.
+ *   - File missing: fall back to env KAFKA_OBSERVER_BROKER_IDS.
+ *   - Read failure (IO/permission): keep last cached value, WARN only — never throws.
+ *   - 5s time-based cache: called from quorum controller event thread on topic creation,
+ *     leader election and AlterPartition; must not hit the disk on every call.
+ *
+ * KRaft deployment note: this file must be present on ALL controller nodes
+ * (the controller quorum may run on machines separate from brokers).
+ */
+final class ObserverReplicas {
+    private static final Logger log = LoggerFactory.getLogger(ObserverReplicas.class);
+
+    private static final long CACHE_TTL_NANOS = 5L * 1000 * 1000 * 1000; // 5s
+
+    private static volatile Set<Integer> cachedIds = Collections.emptySet();
+    private static volatile long lastRefreshNanos = 0L;
+    private static volatile boolean initialized = false;
+
+    private ObserverReplicas() { }
+
+    private static Path filePath() {
+        String p = System.getenv("KAFKA_OBSERVER_IDS_FILE");
+        return Paths.get(p == null ? "/opt/kafka/observer.ids" : p);
+    }
+
+    // Compatibility with v1/v2 deployments: env fallback when file is absent.
+    private static Set<Integer> envFallback() {
+        String env = System.getenv("KAFKA_OBSERVER_BROKER_IDS");
+        Set<Integer> ids = new HashSet<>();
+        if (env != null) {
+            for (String tok : env.split(",")) {
+                String t = tok.trim();
+                if (!t.isEmpty()) {
+                    try {
+                        ids.add(Integer.parseInt(t));
+                    } catch (NumberFormatException ignored) {
+                        // non-numeric tokens silently ignored, same as ObserverIds.scala
+                    }
+                }
+            }
+        }
+        return ids;
+    }
+
+    private static Set<Integer> readFromFile() throws java.io.IOException {
+        Path p = filePath();
+        if (!Files.exists(p)) {
+            return envFallback();
+        }
+        Set<Integer> ids = new HashSet<>();
+        for (String line : Files.readAllLines(p)) {
+            if (line.trim().startsWith("#")) continue;   // full-line comment
+            for (String tok : line.split("[,\\s]+")) {
+                String t = tok.trim();
+                if (!t.isEmpty()) {
+                    try {
+                        ids.add(Integer.parseInt(t));
+                    } catch (NumberFormatException ignored) {
+                        // non-numeric tokens silently ignored
+                    }
+                }
+            }
+        }
+        return ids;
+    }
+
+    /** Current observer id set (5s cache). Never throws. */
+    static Set<Integer> current() {
+        long now = System.nanoTime();
+        // subtraction comparison is safe against nanoTime wraparound; first call always refreshes
+        if (!initialized || now - lastRefreshNanos >= CACHE_TTL_NANOS) {
+            try {
+                Set<Integer> fresh = readFromFile();
+                if (!fresh.equals(cachedIds)) {
+                    log.info("Observer id set changed: {} -> {} (source: {})",
+                        cachedIds, fresh, filePath());
+                }
+                cachedIds = Collections.unmodifiableSet(fresh);
+            } catch (Exception e) {
+                log.warn("Failed to read observer ids from {}, keeping last value {}",
+                    filePath(), cachedIds, e);
+            }
+            lastRefreshNanos = now;
+            initialized = true;
+        }
+        return cachedIds;
+    }
+
+    static boolean isObserver(int brokerId) {
+        return current().contains(brokerId);
+    }
+
+    /**
+     * Filter observers out of an initial ISR (topic creation / partition creation).
+     * If ALL members are observers, keep the original ISR — a new partition must have
+     * a leader — and WARN loudly (misconfiguration: whole assignment marked observer).
+     */
+    static List<Integer> filterInitialIsr(List<Integer> isr) {
+        Set<Integer> observers = current();
+        if (observers.isEmpty()) {
+            return isr;
+        }
+        List<Integer> filtered = new ArrayList<>(isr.size());
+        for (Integer brokerId : isr) {
+            if (!observers.contains(brokerId)) {
+                filtered.add(brokerId);
+            }
+        }
+        if (filtered.isEmpty()) {
+            log.warn("All replicas in initial ISR {} are observers {}; keeping original ISR " +
+                "so the partition has a leader. Check observer configuration.", isr, observers);
+            return isr;
+        }
+        if (filtered.size() != isr.size()) {
+            log.info("Filtered observers {} from initial ISR {} -> {}", observers, isr, filtered);
+        }
+        return filtered;
+    }
+}
